<Window x:Class="FleetManager.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion des Utilisateurs - Fleet Manager" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Style pour les boutons d'action -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton Ajouter (Vert) -->
        <Style x:Key="AddButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Bouton Modifier (Bleu) -->
        <Style x:Key="EditButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#3498DB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Bouton Supprimer (Rouge) -->
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Bouton Annuler (Gris) -->
        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7F8C8D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Bouton Sauvegarder (Vert foncé) -->
        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Bouton Bloquer/Debloquer (Orange) -->
        <Style x:Key="BlockButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#F39C12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E67E22"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Style pour les Labels -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- En-tête -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="👥 Gestion des Utilisateurs" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"/>
                    <TextBlock Text="Ajoutez, modifiez ou supprimez des utilisateurs (Admin uniquement)" 
                               FontSize="13" 
                               Foreground="#7F8C8D"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Rafraîchir" 
                            Style="{StaticResource EditButton}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,10,0"/>
                    <Button Content="← Retour" 
                            Style="{StaticResource CancelButton}"
                            Command="{Binding BackCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Zone principale -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Liste des utilisateurs -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25" Margin="0,0,15,0">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Liste des Utilisateurs" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>
                    
                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Users}" 
                              SelectedItem="{Binding SelectedUser}"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="Transparent"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#F8F9FA">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="120"/>
                            <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="200"/>
                            <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="120"/>
                            <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Formulaire d'édition -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📝 Détails de l'Utilisateur" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Nom *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtNom" 
                                Text="{Binding EditNom, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Prénom *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtPrenom" 
                                Text="{Binding EditPrenom, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Email *" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="txtEmail" 
                                Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ModernTextBox}"
                                Margin="0,0,0,15"/>

                        <TextBlock Text="Mot de passe" Style="{StaticResource FieldLabel}"/>
                        <TextBlock Text="(Laisser vide pour conserver le mot de passe actuel)" 
                                   FontSize="11" 
                                   Foreground="#7F8C8D" 
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="txtMotDePasse" 
                                   Height="35"
                                   Padding="12,8"
                                   FontSize="13"
                                   BorderBrush="#D1D8E0"
                                   BorderThickness="1"
                                   Background="White"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Rôle" Style="{StaticResource FieldLabel}"/>
                        <ComboBox x:Name="cmbRole" 
                                SelectedItem="{Binding EditRole}"
                                Height="35"
                                Padding="12,8"
                                FontSize="13"
                                BorderBrush="#D1D8E0"
                                BorderThickness="1"
                                Background="White"
                                Margin="0,0,0,15">
                            <ComboBoxItem Content="Administrateur"/>
                            <ComboBoxItem Content="Utilisateur"/>
                        </ComboBox>

                        <CheckBox x:Name="chkBloque" 
                                  Content="Bloquer le compte" 
                                  IsChecked="{Binding EditEstBloque}"
                                  Margin="0,0,0,25"
                                  FontSize="13"
                                  Foreground="#2C3E50"/>

                        <!-- Boutons d'action -->
                        <StackPanel>
                            <Button Content="💾 Sauvegarder" 
                                    Command="{Binding SaveUserCommand}"
                                    Style="{StaticResource SaveButton}"
                                    Margin="0,0,0,10"/>
                            
                            <Button Content="❌ Annuler" 
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource CancelButton}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Barre d'actions -->
        <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="➕ Ajouter" 
                        Command="{Binding AddUserCommand}"
                        Style="{StaticResource AddButton}"
                        Margin="0,0,10,0"/>
                
                <Button Content="✏️ Modifier" 
                        Command="{Binding EditUserCommand}"
                        Style="{StaticResource EditButton}"
                        Margin="0,0,10,0"/>
                
                <Button Content="🔓/🔒 Bloquer/Débloquer" 
                        Command="{Binding ToggleBlockUserCommand}"
                        Style="{StaticResource BlockButton}"
                        Margin="0,0,10,0"/>
                
                <Button Content="🗑️ Supprimer" 
                        Command="{Binding DeleteUserCommand}"
                        Style="{StaticResource DeleteButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
