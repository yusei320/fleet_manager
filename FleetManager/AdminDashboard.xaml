<Window x:Class="FleetManager.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FleetManager.Converters"
        Title="Dashboard Administrateur - Fleet Manager" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <converters:PercentageConverter x:Key="PercentageConverter"/>
        <converters:MaxValueConverter x:Key="MaxValueConverter"/>
        <!-- Style pour les Sidebar Items -->
        <Style x:Key="SidebarItem" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les Sidebar Items Actifs -->
        <Style x:Key="SidebarItemActive" TargetType="Button" BasedOn="{StaticResource SidebarItem}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les Cards -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour les Labels de statistiques -->
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Style pour les Valeurs de statistiques -->
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="White" BorderBrush="#D1D8E0" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="30,20">
                    <StackPanel>
                        <TextBlock Text="🚗 Fleet Manager" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="#3498DB"/>
                        <TextBlock Text="Administration" 
                                   FontSize="12" 
                                   Foreground="#7F8C8D"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Menu Navigation -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0">
                    <StackPanel>
                        <TextBlock Text="MENU" 
                                   FontSize="11" 
                                   FontWeight="Bold" 
                                   Foreground="#95A5A6" 
                                   Margin="0,0,0,10"/>
                        
                        <Button Content="📊 Dashboard" 
                                Style="{StaticResource SidebarItemActive}"
                                Command="{Binding NavigateToDashboard}"/>
                        
                        <Button Content="👥 Utilisateurs" 
                                Style="{StaticResource SidebarItem}"
                                Command="{Binding OpenUsersCommand}"/>
                        
                        <Button Content="🚗 Véhicules" 
                                Style="{StaticResource SidebarItem}"
                                Command="{Binding OpenVehiclesCommand}"/>
                        
                        <Button Content="⛽ Suivis" 
                                Style="{StaticResource SidebarItem}"
                                Command="{Binding OpenSuivisCommand}"/>
                        
                        <Button Content="📊 Rapports" 
                                Style="{StaticResource SidebarItem}"
                                Command="{Binding OpenReportsCommand}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- User Info & Logout -->
                <Border Grid.Row="2" Padding="20" Background="#F8F9FA">
                    <StackPanel>
                        <TextBlock Text="👤 Administrateur" 
                                   FontSize="13" 
                                   FontWeight="SemiBold" 
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,10"/>
                        <Button Content="🚪 Déconnexion" 
                                Style="{StaticResource SidebarItem}"
                                Command="{Binding LogoutCommand}"
                                Height="40"
                                Margin="0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Zone Principale -->
        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <Border Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Dashboard Administrateur" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"/>
                    <TextBlock Text="Vue d'ensemble de la flotte" 
                               FontSize="14" 
                               Foreground="#7F8C8D"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Contenu selon la vue -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Cartes de statistiques -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Carte Véhicules -->
                        <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="🚗" FontSize="32" Margin="0,0,0,10"/>
                                <TextBlock Text="Véhicules" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TotalVehicles}" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte Utilisateurs -->
                        <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="👥" FontSize="32" Margin="0,0,0,10"/>
                                <TextBlock Text="Utilisateurs" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TotalUsers}" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte Kilomètres -->
                        <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="📏" FontSize="32" Margin="0,0,0,10"/>
                                <TextBlock Text="Kilomètres" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TotalKilometres, StringFormat=N0}" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte Dépenses -->
                        <Border Grid.Column="3" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="💰" FontSize="32" Margin="0,0,0,10"/>
                                <TextBlock Text="Dépenses (€)" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TotalDepenses, StringFormat=N2}" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Section Graphiques -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Graphique Dépenses par mois -->
                        <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="25" Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="💰 Dépenses par Mois (€)" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"
                                           Margin="0,0,0,15"/>
                                
                                <ItemsControl ItemsSource="{Binding ExpensesByMonth}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Month}" 
                                                           FontSize="12" 
                                                           Foreground="#7F8C8D"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" 
                                                        Background="#3498DB" 
                                                        Height="25" 
                                                        CornerRadius="4"
                                                        Margin="10,0"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding Percentage, Converter={StaticResource PercentageConverter}}"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Value, StringFormat=N2}" 
                                                           FontSize="12" 
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Graphique Carburant par mois -->
                        <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="25">
                            <Border.Effect>
                                <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="⛽ Carburant par Mois (L)" 
                                           FontSize="16" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"
                                           Margin="0,0,0,15"/>
                                
                                <ItemsControl ItemsSource="{Binding FuelByMonth}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Month}" 
                                                           FontSize="12" 
                                                           Foreground="#7F8C8D"
                                                           VerticalAlignment="Center"/>
                                                <Border Grid.Column="1" 
                                                        Background="#27AE60" 
                                                        Height="25" 
                                                        CornerRadius="4"
                                                        Margin="10,0"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding Percentage, Converter={StaticResource PercentageConverter}}"/>
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Value, StringFormat=N1}" 
                                                           FontSize="12" 
                                                           FontWeight="SemiBold"
                                                           Foreground="#2C3E50"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Section Suivis Récents -->
                    <Border Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                        <Border.Effect>
                            <DropShadowEffect Color="#22000000" BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
                        </Border.Effect>
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⛽ Suivis Récents" 
                                           FontSize="18" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"/>
                                <Button Grid.Column="1" Content="🔄 Rafraîchir" 
                                        Height="35" 
                                        Padding="15,0" 
                                        Background="#3498DB" 
                                        Foreground="White" 
                                        BorderThickness="0"
                                        Cursor="Hand"/>
                            </Grid>
                            
                            <DataGrid ItemsSource="{Binding Suivis}" 
                                      AutoGenerateColumns="False" 
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      RowBackground="Transparent"
                                      AlternatingRowBackground="#F8F9FA">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                                    <DataGridTextColumn Header="Véhicule ID" Binding="{Binding IdVehicule}" Width="100"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateSuivi, StringFormat=dd/MM/yyyy}" Width="100"/>
                                    <DataGridTextColumn Header="Carburant (L)" Binding="{Binding CarburantLitre, StringFormat=N2}" Width="100"/>
                                    <DataGridTextColumn Header="Coût (€)" Binding="{Binding Cout, StringFormat=N2}" Width="100"/>
                                    <DataGridTextColumn Header="Distance (km)" Binding="{Binding DistanceKm, StringFormat=N0}" Width="120"/>
                                    <DataGridTextColumn Header="Commentaire" Binding="{Binding Commentaire}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
