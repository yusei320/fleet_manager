<Window x:Class="FleetManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        Title="Fleet Manager" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <!-- Cartes génériques -->
        <Style x:Key="CardBase" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="12" ShadowDepth="2" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton d'action (copié du style Admin) -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="6" ShadowDepth="1" Opacity="0.12"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour le Menu -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les cartes de statistiques -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style pour DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#D1D8E0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF5FB"/>
                    <Setter Property="Foreground" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu supérieur -->
        <Menu DockPanel.Dock="Top" Height="45">
            <MenuItem x:Name="AdminMenu" Header="👨‍💼 Administration" Click="OpenAdmin_Click"/>
            <MenuItem Header="🏠 Accueil" Click="MenuItem_Click"/>
            <MenuItem Header="🚗 Véhicules">
                <MenuItem Header="➕ Ajouter un véhicule" Click="Menu_AddVehicle_Click"/>
                <MenuItem Header="📋 Liste des véhicules" Click="Menu_ListVehicles_Click"/>
            </MenuItem>
            <MenuItem Header="⛽ Suivi">
                <MenuItem Header="➕ Ajouter un suivi" Click="Menu_AddSuivi_Click"/>
                <MenuItem Header="📊 Voir les suivis" Click="Menu_ViewSuivi_Click"/>
            </MenuItem>
        </Menu>

        <!-- Contenu principal -->
        <Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MainContent" Margin="30,20">

                    <!-- Actions globales -->
                    <DockPanel Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Button Content="🔄 Rafraîchir"
                                    Click="BtnRefresh_Click"
                                    Style="{StaticResource ActionButton}"
                                    Background="#3498DB"
                                    Foreground="White"
                                    Margin="0,0,0,0"/>
                            <Button Content="🏠 Accueil"
                                    Click="BtnHome_Click"
                                    Style="{StaticResource ActionButton}"
                                    Background="#95A5A6"
                                    Foreground="White"
                                    Margin="8,0,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- En-tête du tableau de bord -->
                    <Border Style="{StaticResource CardBase}">
                        <DockPanel>
                            <StackPanel>
                                <TextBlock Text="📊 Tableau de Bord" 
                                           FontSize="30" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Vue d'ensemble dynamique de votre flotte"
                                           FontSize="14" 
                                           Foreground="#7F8C8D"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Filtres -->
                    <Border Style="{StaticResource CardBase}">
                        <StackPanel>
                            <TextBlock Text="Filtres"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Véhicule" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="cbVehicleFilter"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Id"
                                              Height="34"
                                              MinWidth="180"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Date début" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="dpStartDate" Height="34"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="Date fin" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="dpEndDate" Height="34"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="Appliquer"
                                            Click="BtnApplyFilters_Click"
                                            Style="{StaticResource ActionButton}"
                                            Background="#27AE60"
                                            Margin="0,0,6,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <CheckBox x:Name="chkAdminAll"
                                              Visibility="Collapsed"
                                              Content="Mode admin : tous les utilisateurs"
                                              Margin="0,0,12,0"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button x:Name="btnToggleAdmin"
                                            Content="🔀 Basculer admin"
                                            Click="BtnToggleAdmin_Click"
                                            Style="{StaticResource ActionButton}"
                                            Background="#8E44AD"
                                            Foreground="White"
                                            Visibility="Collapsed"/>
                                </StackPanel>

                                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button Content="Réinitialiser"
                                            Click="BtnResetFilters_Click"
                                            Style="{StaticResource ActionButton}"
                                            Background="#95A5A6"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Cartes de statistiques -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Carte Kilométrage -->
                        <Border Grid.Column="0" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="🛣️" 
                                           FontSize="32" 
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="Kilométrage Total" 
                                           FontSize="14" 
                                           Foreground="#7F8C8D"
                                           Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtKilometrageTotal" 
                                           Text="0 km" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte Coût -->
                        <Border Grid.Column="1" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="💰" 
                                           FontSize="32" 
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="Coût Total Carburant" 
                                           FontSize="14" 
                                           Foreground="#7F8C8D"
                                           Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtCoutTotal" 
                                           Text="0 €" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"/>
                            </StackPanel>
                        </Border>

                        <!-- Carte Litres -->
                        <Border Grid.Column="2" Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="⛽" 
                                           FontSize="32" 
                                           HorizontalAlignment="Left"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="Carburant consommé" 
                                           FontSize="14" 
                                           Foreground="#7F8C8D"
                                           Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtLitresTotal" 
                                           Text="0 L" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="#2C3E50"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Section graphiques -->
                    <Border Background="White"
                            CornerRadius="10"
                            Padding="25"
                            Margin="0,0,0,25">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="📈"
                                           FontSize="22"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Tendances récentes"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Distance parcourue (6 derniers mois)"
                                               FontSize="14"
                                               Foreground="#7F8C8D"
                                               Margin="0,0,0,8"/>
                                    <oxy:PlotView x:Name="pvDistance"
                                                  Height="280"
                                                  Model="{Binding MonthlyDistanceModel}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <TextBlock Text="Coût carburant (6 derniers mois)"
                                               FontSize="14"
                                               Foreground="#7F8C8D"
                                               Margin="0,0,0,8"/>
                                    <oxy:PlotView x:Name="pvCost"
                                                  Height="280"
                                                  Model="{Binding MonthlyCostModel}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Section Suivis récents -->
                    <Border Background="White" 
                            CornerRadius="10" 
                            Padding="25">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="📋 " 
                                           FontSize="22" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Suivis Récents" 
                                           FontSize="20" 
                                           FontWeight="SemiBold" 
                                           Foreground="#2C3E50"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Border BorderBrush="#D1D8E0" 
                                    BorderThickness="1" 
                                    CornerRadius="8">
                                <DataGrid x:Name="dgRecentSuivi" 
                                         Height="300" 
                                         IsReadOnly="True"/>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>